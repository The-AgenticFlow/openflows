# ═══════════════════════════════════════════════════════════════════════════
# OpenFlows Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Choose ONE mode below by uncommenting the relevant section.
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │  MODE A: Claude (Anthropic)  ← Claude Code with Anthropic API     │
# │  Required: ANTHROPIC_API_KEY, GITHUB_REPOSITORY                      │
# │  Claude Code speaks Anthropic Messages API natively.                 │
# ├──────────────────────────────────────────────────────────────────────┤
# │  MODE B: Codex + OpenAI        ← Codex CLI with OpenAI API key      │
# │  Required: OPENAI_API_KEY, GITHUB_REPOSITORY                         │
# │  Codex CLI speaks OpenAI Chat Completions format natively.           │
# ├──────────────────────────────────────────────────────────────────────┤
# │  MODE C: Codex + Fireworks     ← RECOMMENDED, cost-effective        │
# │  Required: FIREWORKS_API_KEY, GITHUB_REPOSITORY                       │
# │  Fireworks provides OpenAI-compatible endpoints at lower cost.       │
# └──────────────────────────────────────────────────────────────────────┘
#
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
# MODE A: Claude + Anthropic
# ═══════════════════════════════════════════════════════════════════════════
# Claude Code CLI speaks the Anthropic Messages API natively.
# If you have a direct Anthropic API key, no proxy is needed.
#
# PREREQUISITES — Install Claude Code CLI before first use:
#
#   1. Install Claude Code:
#        npm install -g @anthropic-ai/claude-code
#
#   2. Authenticate:
#        claude login
#        (or set ANTHROPIC_API_KEY below)
#
#   3. Test it works:
#        claude -p "say hello"

# DEFAULT_CLI=claude
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-5


# ═══════════════════════════════════════════════════════════════════════════
# MODE B: Codex + OpenAI
# ═══════════════════════════════════════════════════════════════════════════
# Use your OpenAI API key directly with Codex CLI.
# Codex CLI authenticates with OpenAI and uses OpenAI models.
#
# PREREQUISITES — Install and authenticate Codex CLI before first use:
#
#   1. Install Codex:
#        npm install -g @openai/codex
#
#   2. Authenticate with your OpenAI key:
#        echo "your-openai-key" | codex login --with-api-key
#
#   3. Verify login:
#        codex login status
#
#   4. Test it works:
#        codex exec "say hello"

# DEFAULT_CLI=codex
# OPENAI_API_KEY=your_openai_api_key_here


# ═══════════════════════════════════════════════════════════════════════════
# MODE C: Codex + Fireworks (RECOMMENDED for cost savings)
# ═══════════════════════════════════════════════════════════════════════════
# Fireworks AI provides OpenAI-compatible endpoints at lower cost.
# Uncomment the lines below and comment out MODE A and B lines above.
#
# PREREQUISITES — Same Codex CLI install as MODE B, then:
#
#   1. Authenticate Codex with your Fireworks key:
#        echo "your-fireworks-key" | codex login --with-api-key
#
#   2. Verify login:
#        codex login status

DEFAULT_CLI=codex

# Fireworks API key — authenticates with Fireworks.ai
# Get one at: https://app.fireworks.ai/
FIREWORKS_API_KEY=your_fireworks_api_key_here

# OpenAI base URL — tells Codex to use Fireworks instead of OpenAI
# This overrides the default OpenAI endpoint
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1

# OpenAI API key — for Fireworks, use your Fireworks key here too
OPENAI_API_KEY=your_fireworks_api_key_here


# ═══════════════════════════════════════════════════════════════════════════
# SHARED CONFIGURATION (required for all modes)
# ═══════════════════════════════════════════════════════════════════════════

# --- GitHub (REQUIRED) ---

# Target repository in owner/repo format
# OpenFlows will clone this repo, sync issues, create PRs against it
GITHUB_REPOSITORY=owner/repo

# GitHub Personal Access Token with repo scope
# Required for: issue sync, PR creation, CI polling, merging
# Create one at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# GitHub MCP server command — used by NEXUS for GitHub API calls
# Default uses npx to run the official hosted GitHub MCP proxy
GITHUB_MCP_CMD="npx -y @modelcontextprotocol/server-github"


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED: Model Routing (optional)
# ═══════════════════════════════════════════════════════════════════════════
# Model-to-Provider mapping for the Nexus LLM client
# Only needed if you want to route specific models to specific providers

# MODEL_PROVIDER_MAP=glm=anthropic,deepseek=openai,gpt=openai,accounts/fireworks=fireworks

# Fallback order for LLM providers when primary fails
# LLM_FALLBACK=anthropic,openai,fireworks

# Timeout for each LLM provider request (seconds)
LLM_TIMEOUT_SECS=60

# Retry configuration for transient errors
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_MS=1000


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED: FORGE-SENTINEL Timeout Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Time allowed for SENTINEL to complete its evaluation (default: 600 = 10 min)
SPRINTLESS_SENTINEL_TIMEOUT_SECS=600

# Time allowed for FORGE to initialize and write PLAN.md (default: 600 = 10 min)
SPRINTLESS_FORGE_STARTUP_TIMEOUT_SECS=600


# ═══════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════
# RUST_LOG controls tracing output. Format: level,module=path,level
# Levels: error, warn, info, debug, trace

RUST_LOG=info,agent_team=debug,pocketflow_core=debug


# ═══════════════════════════════════════════════════════════════════════════
# Workspace Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Root directory for cloned target repo workspaces and orchestration artifacts.
# Default: ~/.agentflow/workspaces/<repo-name>

AGENTFLOW_WORKSPACE_ROOT=~/.agentflow/workspaces


# ═══════════════════════════════════════════════════════════════════════════
# CODER MODE CONFIGURATION (optional)
# ═══════════════════════════════════════════════════════════════════════════
# Set WORKSPACE_PROVIDER=coder in registry.json to enable.
# When enabled, agents run in ephemeral Coder workspaces instead of local.

# Coder server URL (required for Coder mode)
# CODER_URL=http://localhost:7080

# Coder admin password (for bootstrap)
# CODER_ADMIN_PASSWORD=Op3nFl0ws!

# Enable Coder AI Gateway (Premium) — routes LLM calls through Coder
# so API keys never leak into workspace env vars.
# When enabled (the default), the FORGE/SENTINEL harness omits `--model`
# and lets the AI Gateway manage model selection from its configured list.
# When disabled, the harness injects `--model` from each agent's
# `model_backend` in orchestration/agent/registry.json (direct-API or
# LiteLLM-proxy mode). This env var is the authority; when unset, each
# agent's `coder_module.params.enable_ai_gateway` in registry.json is used.
# USE_AI_GATEWAY=true

# LiteLLM proxy fallback URL — used when AI Gateway is off or for
# providers that AI Gateway doesn't yet support.
# LITELLM_PROXY_URL=http://proxy:4000

# Host-side path to a pre-built CLI ELF binary. When set (or auto-detected
# via `command -v <cli>`), it is bind-mounted read-only into each Coder
# workspace and symlinked onto PATH, so the agent module can skip its startup
# download. Essential when the download endpoint is slow/unreachable from the
# host. Works for any CLI backend (claude, codex, aider, goose, ...).
# The env var name is HOST_<CLI>_BINARY (e.g. HOST_CLAUDE_BINARY,
# HOST_CODEX_BINARY). Leave unset to auto-detect via `command -v`.
# HOST_CLAUDE_BINARY=/usr/lib/node_modules/@anthropic-ai/claude-code/bin/claude.exe
# HOST_CODEX_BINARY=/usr/local/bin/codex

# ── Notifications (awaiting_human escalations) ──
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── Slackme Module (Coder external auth, per-command DMs) ──
# ENABLE_SLACKME=false
# CODER_EXTERNAL_AUTH_1_TYPE=slack
# CODER_EXTERNAL_AUTH_1_CLIENT_ID=your_slack_client_id
# CODER_EXTERNAL_AUTH_1_CLIENT_SECRET=your_slack_client_secret
