# ─────────────────────────────────────────────────────────────────────────────
# AgentFlow Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# Two modes are supported:
#
# 1. PROXY MODE (Recommended — always preferred)
#    - Set PROXY_URL to your proxy endpoint (LiteLLM or anthropic-proxy)
#    - Set PROXY_API_KEY for proxy authentication
#    - Optionally set GATEWAY_URL + GATEWAY_API_KEY for the upstream backend
#    - Individual API keys (ANTHROPIC_API_KEY, etc.) serve as FALLBACK only
#      and are used when the proxy returns a transient error (503, timeout).
#
# 2. DIRECT MODE (Fallback only)
#    - Do NOT set PROXY_URL
#    - Set individual API keys for each provider you want to use
#    - LLM_FALLBACK controls which providers to try and in what order
#
# Key priority order (always):
#   PROXY_API_KEY > GATEWAY_API_KEY > ANTHROPIC_API_KEY / GEMINI_API_KEY / OPENAI_API_KEY
#
# ─────────────────────────────────────────────────────────────────────────────

# ═══════════════════════════════════════════════════════════════════════════
# PROXY MODE (LiteLLM or Anthropic-to-OpenAI proxy) — ALWAYS PREFERRED
# ═══════════════════════════════════════════════════════════════════════════
# When PROXY_URL is set, the proxy client is tried first. Direct API keys
# are appended as fallbacks so a transient proxy failure doesn't block the
# entire orchestration pipeline.u

# Proxy URL (enables proxy mode — required for proxy-first routing)
PROXY_URL=http://localhost:8080/v1

# Proxy API key — highest priority key in the system.
# Used for authenticating with the proxy. Takes precedence over all other keys.
PROXY_API_KEY=your-proxy-key-or-routing-key

# Model name mapping for proxy (optional, comma-separated from=to pairs)
# Maps model names from registry to proxy-compatible names
# Example: claude-haiku-4-5-20251001=kimi-k2.5
MODEL_MAP=claude-haiku-4-5-20251001=kimi-k2.5

# ═══════════════════════════════════════════════════════════════════════════
# DIRECT MODE (Individual API Keys)
# ═══════════════════════════════════════════════════════════════════════════

# Fallback order (comma-separated, tried in order)
# Only used in DIRECT mode (when PROXY_URL is not set)
# Default: anthropic,gemini,openai
LLM_FALLBACK=anthropic,gemini

# Model-to-Provider mapping (prefix=provider pairs)
# Maps model names from registry.json to the correct API client format.
# Example: glm-5 -> openai (sends OpenAI-format requests)
MODEL_PROVIDER_MAP=glm=openai,deepseek=openai,gpt=openai

# Timeout for each provider (seconds)
LLM_TIMEOUT_SECS=60

# Retry configuration for gateway timeouts and transient errors
# Max retries per provider before falling back to next provider
LLM_MAX_RETRIES=3
# Initial delay between retries (ms), doubles each retry (exponential backoff)
LLM_RETRY_DELAY_MS=1000

# ─────────────────────────────────────────────────────────────────────────────
# Direct Provider Keys (FALLBACK when proxy is configured)
# ─────────────────────────────────────────────────────────────────────────────
# These are only used when PROXY_URL is NOT set (direct mode), or as fallback
# when the proxy returns a transient error. In proxy mode, set these ONLY if
# you want fallback coverage — the proxy handles all primary routing.

# Anthropic (Claude)
# Required in DIRECT mode if using anthropic provider
# Optional in PROXY mode - proxy handles authentication
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# OpenAI
# Required in DIRECT mode if using openai provider
# Optional in PROXY mode
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
# Required in DIRECT mode if using gemini provider
# Optional in PROXY mode
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# Fireworks AI
# When set, replaces proxy mode with Fireworks gateway
# Takes priority over PROXY_URL when configured
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p2

# ═══════════════════════════════════════════════════════════════════════════
# CLI Backend Configuration
# ═══════════════════════════════════════════════════════════════════════════
# The orchestration system supports multiple CLI backends for agent execution:
# - Claude Code CLI (default): Anthropic's official CLI
# - Codex CLI: OpenAI's Codex CLI

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code CLI Configuration (Default Backend)
# ─────────────────────────────────────────────────────────────────────────────
# Path to Claude CLI binary. REQUIRED when using Claude backend.
# Find your path with: which claude
# If not set, defaults to "claude" (expects it in PATH)
CLAUDE_PATH=claude

# ─────────────────────────────────────────────────────────────────────────────
# Codex CLI Configuration (Alternative Backend)
# ─────────────────────────────────────────────────────────────────────────────
# Path to Codex CLI binary. REQUIRED when using Codex backend.
# Install: npm install -g @openai/codex
# Find your path with: which codex
# If not set, defaults to "codex" (expects it in PATH)
CODEX_PATH=codex

# Codex approval mode for autonomous operation.
# Options: suggest (default), auto-edit, full-auto
# - suggest: Codex suggests changes, requires approval
# - auto-edit: Codex can edit files automatically
# - full-auto: Codex can execute commands and edit files (recommended for agents)
CODEX_APPROVAL_MODE=full-auto

# Codex model selection (uses OPENAI_MODEL from above)
# Codex CLI will use the model specified in OPENAI_MODEL environment variable.
# For custom gateways (Fireworks, etc.), also set OPENAI_BASE_URL:
#   OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
# Note: OPENAI_API_URL is also supported for backwards compatibility and will
# be automatically converted to OPENAI_BASE_URL (stripping /chat/completions suffix).

# Default CLI backend for all agents (environment variable override)
# This OVERRIDES the default_cli field in registry.json
# Options: claude, codex
# Priority order for CLI backend selection:
#   1. Agent-specific "cli" field in registry.json (highest)
#   2. DEFAULT_CLI environment variable
#   3. default_cli field in registry.json
#   4. Hardcoded "claude" fallback (lowest)
DEFAULT_CLI=claude

# ═══════════════════════════════════════════════════════════════════════════
# GitHub Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Target repository (owner/repo format)
GITHUB_REPOSITORY=owner/repo

# GitHub Personal Access Token with repo scope
# Required for: issue sync, PR creation, CI polling, merging
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# GitHub MCP server command
# Default uses npx to run the official GitHub MCP server
GITHUB_MCP_CMD="npx -y @modelcontextprotocol/server-github"

# ═══════════════════════════════════════════════════════════════════════════
# Upstream Gateway (for local anthropic-proxy)
# ═══════════════════════════════════════════════════════════════════════════
# When your upstream gateway only supports OpenAI format, run the local proxy:
#   cargo run -p anthropic-proxy
# This translates Claude CLI's Anthropic requests to OpenAI format and forwards
# to GATEWAY_URL. GATEWAY_API_KEY is second in priority after PROXY_API_KEY.

# Remote gateway URL (OpenAI-compatible) — defaults to Fireworks
GATEWAY_URL=https://api.fireworks.ai/inference/v1/

# Gateway API key — second highest priority after PROXY_API_KEY
GATEWAY_API_KEY=your-gateway-api-key-here

# ═══════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════

RUST_LOG=info,agent_team=debug,pocketflow_core=debug

# ═══════════════════════════════════════════════════════════════════════════
# Workspace Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Root directory for cloned target repo workspaces, worktrees, and
# orchestration artifacts (CONFLICT_RESOLUTION.md, STATUS.json, etc.).
# VESSEL uses this to locate worktrees for conflict resolution and to
# write CONFLICT_RESOLUTION.md for forge_pair rework instructions.
# If not set, conflict resolution files cannot be written and merge
# conflicts will be marked as failed instead of routed for rework.
# Default: ~/.agentflow/workspaces/<repo-name>

AGENTFLOW_WORKSPACE_ROOT=~/.agentflow/workspaces