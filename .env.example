# ═══════════════════════════════════════════════════════════════════════════
# AgentFlow Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
#
# Choose ONE mode below. Comment out the others.
#
# ┌──────────────────────────────────────────────────────────────────────┐
# │  MODE A: Codex + Fireworks     ← RECOMMENDED, simplest setup      │
# │  No proxy needed. Codex is OpenAI-compatible natively.             │
# │  Required: DEFAULT_CLI, FIREWORKS_API_KEY, GITHUB_REPOSITORY       │
# ├──────────────────────────────────────────────────────────────────────┤
# │  MODE B: Claude + Direct Key   ← If you have an Anthropic key     │
# │  No proxy needed. Claude Code speaks Anthropic natively.           │
# │  Required: DEFAULT_CLI, ANTHROPIC_API_KEY, GITHUB_REPOSITORY       │
# ├──────────────────────────────────────────────────────────────────────┤
# │  MODE C: Claude + Proxy        ← Route Claude through a gateway   │
# │  Proxy REQUIRED — Claude Code is NOT OpenAI-compatible.            │
# │  Required: DEFAULT_CLI, PROXY_URL, GATEWAY_URL, GITHUB_REPOSITORY  │
# │  Must run: cargo run -p anthropic-mock  (before starting agentflow) │
# └──────────────────────────────────────────────────────────────────────┘
#
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════
# MODE A: Codex + Fireworks (RECOMMENDED) / Codex + OpenAI
# ═══════════════════════════════════════════════════════════════════════════
# Codex CLI speaks the OpenAI Chat Completions format, which Fireworks, OpenAI,
# and most other providers support natively. No proxy translation needed.
#
# Two sub-options:
#   A1) Codex + Fireworks — set FIREWORKS_API_KEY + OPENAI_BASE_URL (Fireworks URL)
#   A2) Codex + OpenAI    — set OPENAI_API_KEY only (no OPENAI_BASE_URL needed)
#
# PREREQUISITES — Install and authenticate Codex CLI before first use:
#
#   1. Install Codex:
#        npm install -g @openai/codex
#
#   2. Authenticate (one of):
#        a) Login with API key via stdin:
#             echo "your-fireworks-key" | codex login --with-api-key
#        b) Or login with OpenAI key:
#             echo "your-openai-key" | codex login --with-api-key
#        c) Or device auth (for OpenAI accounts):
#             codex login --device-auth
#
#   3. Verify login:
#        codex login status
#
#   4. Test it works:
#        codex exec "say hello"
#
# To use this mode: Uncomment the lines below. Comment out MODES B and C.

# CLI backend — "codex" tells AgentFlow to spawn Codex CLI for FORGE agents
DEFAULT_CLI=codex

# Fireworks API key — authenticates with Fireworks.ai
# Get one at: https://app.fireworks.ai/
# Also used by the Nexus LLM client (via FireworksClient) for orchestration decisions
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Fireworks model — the model identifier on Fireworks' platform
# Must match a model available on your Fireworks account
# Examples: accounts/fireworks/models/kimi-k2p5, accounts/fireworks/models/llama-v3p1-8b-instruct
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p5

# Codex CLI binary path — set to absolute path if not in PATH
# Install: npm install -g @openai/codex
# Find path: which codex
CODEX_PATH=codex

# OpenAI base URL — tells Codex to use Fireworks instead of OpenAI
# Required for Codex+Fireworks. Fireworks speaks OpenAI format natively.
# For Codex+OpenAI (direct key), leave OPENAI_BASE_URL unset — Codex defaults
# to https://api.openai.com/v1 automatically.
# Also used by the Nexus LLM client (via OpenAiClient) as a fallback.
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1

# OpenAI API key — used by the Nexus LLM client as fallback
# When using Fireworks, set this to your Fireworks key (same as FIREWORKS_API_KEY)
# When using OpenAI directly, set this to your OpenAI key (and leave OPENAI_BASE_URL unset)
OPENAI_API_KEY=your_fireworks_or_openai_api_key_here

# OpenAI model — model name for the Nexus LLM client fallback
# When using Fireworks, use a Fireworks model identifier
# When using OpenAI directly, use an OpenAI model name (e.g. gpt-4o-mini)
OPENAI_MODEL=accounts/fireworks/models/kimi-k2p5


# ═══════════════════════════════════════════════════════════════════════════
# MODE B: Claude + Direct Anthropic Key
# ═══════════════════════════════════════════════════════════════════════════
# Claude Code CLI speaks the Anthropic Messages API natively.
# If you have a direct Anthropic API key, no proxy is needed.
#
# PREREQUISITES — Install Claude Code CLI before first use:
#
#   1. Install Claude Code:
#        npm install -g @anthropic-ai/claude-code
#
#   2. Authenticate:
#        claude login
#        (or set ANTHROPIC_API_KEY below)
#
#   3. Test it works:
#        claude -p "say hello"
#
# To use this mode: Uncomment the lines below. Comment out MODES A and C.

# DEFAULT_CLI=claude
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# CLAUDE_PATH=claude


# ═══════════════════════════════════════════════════════════════════════════
# MODE C: Claude + Proxy (for third-party gateways)
# ═══════════════════════════════════════════════════════════════════════════
# Claude Code uses the Anthropic Messages format, which is NOT OpenAI-compatible.
# Most third-party providers (Fireworks, Together, etc.) only speak OpenAI format.
# The local anthropic-mock proxy translates between the two formats in real-time.
#
# YOU MUST START THE PROXY BEFORE RUNNING AGENTFLOW:
#   cargo run -p anthropic-mock
#   (or: ./scripts/start_proxy.sh)
#
# PREREQUISITES — Same Claude Code install as MODE B, plus the proxy.
#
# To use this mode: Uncomment the lines below. Comment out MODES A and B.

# DEFAULT_CLI=claude
# CLAUDE_PATH=claude
# ANTHROPIC_API_KEY=your-anthropic-or-proxy-key

# Proxy URL — where Claude Code sends its Anthropic-format requests
# The proxy (anthropic-mock) listens here and translates to OpenAI format
# PROXY_URL=http://localhost:8765/v1

# Proxy API key — authenticates with the proxy
# When using anthropic-mock, this is forwarded to the gateway as the API key
# PROXY_API_KEY=your-gateway-api-key

# Model mapping — comma-separated from=to pairs
# Maps Anthropic model names (sent by Claude CLI) to gateway-compatible model names
# Used by anthropic-mock to translate model names before forwarding
# MODEL_MAP=claude-haiku-4-5-20251001=accounts/fireworks/models/kimi-k2p6,...

# Gateway URL — the OpenAI-compatible endpoint the proxy forwards to
# This is where the proxy sends translated OpenAI-format requests
# GATEWAY_URL=https://api.fireworks.ai/inference/v1/

# Gateway API key — authenticates with the upstream gateway
# Falls back to PROXY_API_KEY if not set
# GATEWAY_API_KEY=your-gateway-api-key


# ═══════════════════════════════════════════════════════════════════════════
# SHARED CONFIGURATION (required for all modes)
# ═══════════════════════════════════════════════════════════════════════════

# --- GitHub (REQUIRED) ---

# Target repository in owner/repo format
# AgentFlow will clone this repo, sync issues, create PRs against it
GITHUB_REPOSITORY=owner/repo

# GitHub Personal Access Token with repo scope
# Required for: issue sync, PR creation, CI polling, merging
# Create one at: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# GitHub MCP server command — used by NEXUS for GitHub API calls
# Default uses npx to run the official hosted GitHub MCP proxy
GITHUB_MCP_CMD="npx -y @modelcontextprotocol/server-github"

# GitHub MCP server type — "hosted" (default) or "docker"
# "hosted" = uses the GitHub MCP proxy via npx (recommended)
# "docker" = runs the GitHub MCP server in a Docker container
# GITHUB_MCP_TYPE=hosted

# Per-agent GitHub tokens (optional — falls back to GITHUB_PERSONAL_ACCESS_TOKEN)
# Useful for rate limit isolation and scope restriction per agent
# AGENT_NEXUS_GITHUB_TOKEN=ghp_nexus_token
# AGENT_FORGE_GITHUB_TOKEN=ghp_forge_token
# AGENT_SENTINEL_GITHUB_TOKEN=ghp_sentinel_token
# AGENT_VESSEL_GITHUB_TOKEN=ghp_vessel_token
# AGENT_LORE_GITHUB_TOKEN=ghp_lore_token


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED: Model Routing & Fallback
# ═══════════════════════════════════════════════════════════════════════════
# These control how the NEXUS LLM client routes requests.
# Most users don't need to change these — the mode selection above handles it.

# Model-to-Provider mapping (prefix=provider pairs)
# Maps model names from registry.json model_backend to the correct API client.
# "accounts/fireworks=fireworks" ensures Fireworks models use FireworksClient
# directly instead of falling through to the Anthropic proxy.
MODEL_PROVIDER_MAP=glm=anthropic,deepseek=openai,gpt=openai,accounts/fireworks=fireworks

# Fallback order for DIRECT mode (when no model_override from registry)
# Comma-separated, tried in order. Only used when PROXY_URL is NOT set.
# Default: anthropic,gemini,openai
LLM_FALLBACK=anthropic,gemini

# Timeout for each LLM provider request (seconds)
LLM_TIMEOUT_SECS=60

# Retry configuration for transient errors (timeouts, 502, 503, 429)
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_MS=1000


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED: FORGE-SENTINEL Timeout Configuration
# ═══════════════════════════════════════════════════════════════════════════
# These must be greater than LLM_TIMEOUT_SECS to allow the LLM time to respond.
# If SENTINEL times out before the LLM responds, the process will be killed.

# Time allowed for SENTINEL to complete its evaluation (default: 600 = 10 min)
SPRINTLESS_SENTINEL_TIMEOUT_SECS=600

# Time allowed for FORGE to initialize and write PLAN.md (default: 600 = 10 min)
SPRINTLESS_FORGE_STARTUP_TIMEOUT_SECS=600


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED: Additional Provider Keys (optional)
# ═══════════════════════════════════════════════════════════════════════════
# Only needed if you want to use these providers directly (not through Fireworks).
# In MODE A (Codex + Fireworks), these are NOT required.

# Google Gemini — for SENTINEL code review via direct key
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite


# ═══════════════════════════════════════════════════════════════════════════
# ADVANCED: Storage
# ═══════════════════════════════════════════════════════════════════════════
# By default, AgentFlow uses an in-memory store. For persistence across restarts,
# set REDIS_URL to use Redis as the shared store backend.

# REDIS_URL=redis://localhost:6379


# ═══════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════
# RUST_LOG controls tracing output. Format: level,module=path,level
# Levels: error, warn, info, debug, trace

RUST_LOG=info,agent_team=debug,pocketflow_core=debug


# ═══════════════════════════════════════════════════════════════════════════
# Workspace Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Root directory for cloned target repo workspaces and orchestration artifacts.
# Default: ~/.agentflow/workspaces/<repo-name>

AGENTFLOW_WORKSPACE_ROOT=~/.agentflow/workspaces
