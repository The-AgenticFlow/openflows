{
  "default_cli": "codex",
  "allowed_domains": [
    "api.github.com",
    "*.github.com",
    "pypi.org",
    "registry.npmjs.org",
    "crates.io"
  ],
  "team": [
    {
      "id": "nexus",
      "cli": "codex",
      "active": true,
      "instances": 1,
      "model_backend": "openai/gpt-5.5",
      "routing_key": "nexus-key",
      "github_token_env": "AGENT_NEXUS_GITHUB_TOKEN",
      "allowed_domains": null,
      "workspace_provider": "coder",
      "coder_module": {
        "source": "registry.coder.com/coder-labs/codex/coder",
        "version": "VERIFY_ON_REGISTRY",
        "params": {
          "enable_ai_gateway": true,
          "permission_mode": "plan",
          "workdir": "/home/coder/workspace"
        }
      }
    },
    {
      "id": "forge",
